# ─── Обязательные ──────────────────────────────────────────────────────────────
BOT_TOKEN=            # Токен бота от @BotFather
ADMIN_ID=             # Telegram user ID администратора
CHANNEL_ID=           # ID или @username канала для публикации

# ─── Telethon (необязательно) ──────────────────────────────────────────────────
# Без этих переменных бот читает каналы через t.me/s (только публичные каналы).
# Заполни, если нужен доступ к приватным каналам или более стабильное чтение.
# Получи на https://my.telegram.org → API development tools
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=       # Номер телефона в формате +79001234567

# ─── OpenAI / совместимый API (генерация выжимок) ─────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1   # Для других провайдеров укажи их URL
OPENAI_MODEL=gpt-4o-mini                    # Или любая другая поддерживаемая модель

# ─── Параметры выжимки ─────────────────────────────────────────────────────────
DIGEST_HOURS=24       # За сколько часов назад собирать новости
DIGEST_MAX_POSTS=20   # Максимум постов с одного канала
